{
  "name": "local-search-engine",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "start:api": "node repo/apps/api-gateway/src/server.js",
    "start:tracking": "node repo/services/tracking-service/src/server.js",
    "test:phase10": "node repo/services/tracking-service/src/phase10-smoke-test.js",
    "test:phase12-hardening": "node repo/services/user-service/src/phase12-hardening-smoke-test.js",
    "test:shop-first-e2e": "node tmp-shop-first-e2e-suite.js",
    "docker:up": "docker compose -f artifacts/infra/docker/docker-compose.dev.yml up -d",
    "docker:down": "docker compose -f artifacts/infra/docker/docker-compose.dev.yml down",
    "docker:reset": "docker compose -f artifacts/infra/docker/docker-compose.dev.yml down -v && docker compose -f artifacts/infra/docker/docker-compose.dev.yml up -d"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.71.0",
    "@opentelemetry/exporter-jaeger": "^2.6.0",
    "@opentelemetry/resources": "^2.6.0",
    "@opentelemetry/sdk-node": "^0.213.0",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "express": "^4.21.2",
    "ioredis": "^5.4.2",
    "jsonwebtoken": "^9.0.2",
    "kafkajs": "^2.2.4",
    "pg": "^8.13.1",
    "pino": "^10.3.1",
    "ws": "^8.19.0",
    "zod": "^3.24.1"
  }
}
